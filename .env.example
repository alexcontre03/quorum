# Jira Cloud local configuration
JIRA_BASE_URL=https://contrerastfg.atlassian.net
JIRA_EMAIL=tu_correo_atlassian
JIRA_API_TOKEN=pega_aqui_tu_nuevo_token
JIRA_PROJECT_KEY=SCRUM
JIRA_ISSUE_TYPE=Task

# Git local (D003): repositorio clonado en disco que el git_evidence_agent
# consulta vía `git log --grep`. Opcional; si no se configura, el agente
# de Git local se salta sin romper nada.
GIT_REPO_PATH=

# GitHub (D023): integración de SOLO LECTURA con un repositorio remoto.
# El sistema busca PRs y commits que referencien el Jira issue key del
# compromiso para detectar el ciclo de implementación: PR abierto mueve el
# compromiso a `in_code_review`, PR mergeado a `evidenced`. Nunca crea
# ramas, issues ni comentarios; solo lee.
#
# 1) Crear un Personal Access Token (PAT) en GitHub:
#    Profile → Settings → Developer settings → Personal access tokens →
#    Tokens (classic) → Generate new token → scope `repo` (solo lectura).
#    Si el repo es público basta con `public_repo`.
#
# 2) Indicar el repositorio con la forma `owner/repo` (ej.
#    `alexcontre/meeting-traceability` o cualquier repo tuyo de prueba).
#    Puede ser privado si el PAT tiene acceso.
#
# 3) Convención esperada: los PRs deben mencionar el Jira issue key (ej.
#    `PAY-123: add structured logs`) en su title o body. El sistema busca
#    esa cadena vía /search/issues. Si el compromiso no tiene Jira issue
#    todavía, el agente cae al fallback de keywords del título.
#
# Si no se configura, GET /api/github/config devuelve configured=false y el
# sistema se comporta exactamente igual que antes de la integración.
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_URL=https://api.github.com

# Embeddings (D012): por defecto `embeddinggemma:latest` vía Ollama local.
# EMBEDDING_ENABLED=0 desactiva el RAG entero (Q&A y retrieval phase).
EMBEDDING_ENABLED=1
EMBEDDING_BASE_URL=http://127.0.0.1:11434/api
EMBEDDING_MODEL=embeddinggemma:latest

# Runtime providers alternativos (D018-D019): activables desde la UI con
# el toggle Local/OpenAI/Anthropic. Para usarlos hace falta la API key.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022
