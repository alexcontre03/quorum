# ─────────────────────────────────────────────────────────────────
# Quórum — .gitignore
# ─────────────────────────────────────────────────────────────────

# Secrets and local config
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
.mypy_cache/
.ruff_cache/

# Node / Vite
node_modules/
dist/
.vite/
*.tsbuildinfo

# Frontend build artefact (regenerated by `npm run build`)
app/static/

# Application runtime data (regenerated by use)
app/data/analysis_runs/
app/data/commitments/
app/data/retrieval_index/
app/data/qa_audit/
app/data/runtime_profile.json
app/data/settings/runtime_profile.json
app/data/settings/runtime_settings.json

# evaluation_runs/ and followup_evaluation_runs/ are NOT ignored: they hold
# the headline figures referenced from the memoir's Appendix B and let any
# reviewer reproduce the cited numbers without re-running the pipeline.

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Word transient lockfiles (created when a .docx is open)
~$*

# Memoir lives outside the public repository — academic deliverable only.
memoria/

# Internal documentation (LLM Wiki layer, raw sources, tutor feedback)
.docs-internal/

# Scratch / working files
tmp_*
img_dump/
**/_review_status.md
**/_preview_*.png

# Agent / harness configuration kept out of the public repo
.agents/
.claude/
.impeccable/
skills-lock.json
AGENTS.md
RESUMEN_PROYECTO.md
